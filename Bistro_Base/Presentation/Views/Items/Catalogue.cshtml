@using Common.Models
@using Common.Interfaces
@model IEnumerable<IitemValidating>

@{
    var currentSimulateUser = ViewData["simulateUser"]?.ToString() ?? "guest";
    var viewType = ViewData["viewType"]?.ToString() ?? "approved";

    // Only restaurants
    var restaurantItems = Model?
        .OfType<Restaurant>()     // CAST IitemValidating → Restaurant
        .ToList() ?? new List<Restaurant>();

    // Filter based on viewType
    if (viewType == "approved")
    {
        restaurantItems = restaurantItems.Where(r => r.Status == true).ToList();
    }
    else if (viewType == "pending")
    {
        restaurantItems = restaurantItems.Where(r => r.Status == null).ToList();
    }
}

<div class="container mt-3">

    <!-- Buttons -->
    <div class="mb-3 d-flex gap-2">
        <form method="get" asp-action="Index">
            <input type="hidden" name="simulateUser" value="@currentSimulateUser" />
            <input type="hidden" name="viewType" value="pending" />
            <button type="submit" class="btn btn-warning btn-lg">Show Pending</button>
        </form>

        <form method="get" asp-action="Index">
            <input type="hidden" name="simulateUser" value="@currentSimulateUser" />
            <input type="hidden" name="viewType" value="approved" />
            <button type="submit" class="btn btn-success btn-lg">Show Approved</button>
        </form>
    </div>

    @if (!restaurantItems.Any())
    {
        <div class="alert alert-info mt-3">
            @if (viewType == "approved")
            {
                @:No approved items to show.
            }
            else
            {
                @:No pending items to show.
            }
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var r in restaurantItems)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow">

                        <img src="~/@r.ImagePath.Replace("wwwroot/", "")"
                             class="card-img-top"
                             alt="@r.Name"
                             style="height:180px; object-fit:cover;" />

                        <div class="card-body">
                            <h5 class="card-title">@r.Name</h5>
                            <p class="card-text">@r.Description</p>

                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><b>Owner:</b> @r.OwnerEmailAddress</li>
                                <li class="list-group-item"><b>Address:</b> @r.Address</li>
                                <li class="list-group-item"><b>Phone:</b> @r.Phone</li>
                            </ul>

                            <p class="mt-2">
                                <b>Status:</b>
                                @if (r.Status == true)
                                {
                                    <span class="text-success">Approved</span>
                                }
                                else if (r.Status == false)
                                {
                                    <span class="text-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="text-danger" style="text-decoration: underline;">Pending</span>
                                }
                            </p>

                            @* Show checkbox only if pending *@
                            @if (r.Status == null)
                            {
                                <div class="form-check mt-2">
                                    <input type="checkbox" name="selectedIds" value="@r.Id" class="form-check-input" />
                                    <label class="form-check-label">Select for approval/rejection</label>
                                </div>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>