@using Common.Models
@using Common.Interfaces
@model IEnumerable<IitemValidating>

@{
    var viewType = ViewData["viewType"]?.ToString() ?? "approved";
}

<div class="container mt-3">

    <div class="mb-3 d-flex gap-2">
        <form asp-action="Verification" method="get">
            <button type="submit" class="btn btn-warning btn-lg">Show Pending</button>
        </form>

        <form asp-action="Index" method="get">
            <button type="submit" class="btn btn-success btn-lg">Show Approved</button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            @(viewType == "approved" ? "No approved items." : "No pending items.")
        </div>
    }
    else
    {
        <form asp-action="ApproveStatus" method="post">

            <!-- RESTAURANTS -->
            @if (Model.OfType<Restaurant>().Any())
            {
                <div class="row">
                    @foreach (var r in Model.OfType<Restaurant>())
                    {
                        <div class="col-md-4 mb-3">
                            @await Html.PartialAsync("_RestaurantPartial", r)
                        </div>
                    }
                </div>
            }

            <!-- MENU ITEMS -->
            @if (Model.OfType<MenuItem>().Any())
            {
                <table class="table table-striped table-hover mt-4">
                    <thead>
                        <tr>
                            <th></th>
                            <th>Title</th>
                            <th>Price</th>
                            <th>Currency</th>
                            <th>Restaurant</th>
                            <th>
                                @(viewType == "pending" ? "Approve" : "Status")
                            </th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var m in Model.OfType<MenuItem>())
                        {
                            @await Html.PartialAsync("_MenuItemPartial", m)
                        }
                    </tbody>
                </table>
            }

            @if (viewType == "pending")
            {
                <button type="submit" class="btn btn-success btn-lg mt-3">
                    Approve Selected
                </button>
            }

        </form>
    }

</div>