@model List<Common.Interfaces.IitemValidating>
@using Common.Interfaces
@using Common.Models
@using DataAccess.Repositories

@{
    ViewData["Title"] = "Import Data";
    var items = Model ?? new List<IitemValidating>();
    var restaurants = items.OfType<Restaurant>().ToList();
    var menuItems = items.OfType<MenuItem>().ToList();
}

<div class="flex-grow-1 px-3 py-4">
    <h2 class="fw-bold mb-4">Data Import</h2>

    <form asp-controller="BulkImport" asp-action="Import" method="post" enctype="multipart/form-data" class="mb-4">
        <div class="mb-3">
            <label class="form-label">
                Kindly select a JSON file that complies with the specified structure and formatting requirements.
            </label>
            <input type="file" name="file" class="form-control" accept=".json" required />
        </div>
        <button type="submit" class="btn btn-primary">Upload</button>
    </form>
    <hr class="my-4" />

    @if (restaurants.Any())
    {
        <h3 class="fw-bold fs-4 mb-3">Restaurants</h3>
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Bistrobase ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Owner Email</th>
                        <th>Address</th>
                        <th>Phone</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in restaurants)
                    {
                        <tr>
                            <td>@r.BistrobaseId</td>
                            <td>@r.Name</td>
                            <td>@r.Description</td>
                            <td>@r.OwnerEmailAddress</td>
                            <td>@r.Address</td>
                            <td>@r.Phone</td>
                            <td>@(r.Status == null ? "Pending" : r.Status == true ? "Approved" : "Rejected")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (menuItems.Any())
    {
        <h3 class="fw-bold fs-4 mt-5 mb-3">Menu Items</h3>
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Bistrobase ID</th>
                        <th>Title</th>
                        <th>Price</th>
                        <th>Currency</th>
                        <th>Restaurant</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in menuItems)
                    {
                        var restaurantName = m.Restaurant?.Name ?? "N/A";
                        <tr>
                            <td>@m.BistrobaseId</td>
                            <td>@m.Title</td>
                            <td>@m.Price</td>
                            <td>@m.Currency</td>
                            <td>@restaurantName</td>
                            <td>@(m.Status == null ? "Pending" : m.Status == true ? "Approved" : "Rejected")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (!items.Any())
    {
        <p>No items uploaded yet.</p>
    }

    @if (items.Any())
    {
        <hr class="my-4" />

        <!-- Download ZIP -->
        <div class="mb-4">
            <h4 class="fw-bold mb-3">Download Default Images ZIP</h4>
            <p>
                Follow these steps to download the default images ZIP:
            </p>
            <ol>
                <li>No filename input is needed; the field is empty by default.</li>
                <li>The ZIP file will always be named <b>images.zip</b>.</li>
                <li>The ZIP contains default images for all restaurants and menu items.</li>
                <li>Simply click the "Download ZIP" button to generate the file.</li>
            </ol>

            <form asp-controller="BulkImport" asp-action="DownloadZip" method="post">
                <!-- Input removed, filename is fixed -->
                <button type="submit" class="btn btn-success">Download ZIP</button>
            </form>
        </div>

        <hr class="my-4" />

        <!-- Upload ZIP -->
        <div class="mb-4">
            <h4 class="fw-bold mb-3">Upload Edited Images ZIP</h4>

            <p>
                To update the images in the system, follow these steps:
            </p>
            <ol>
                <li>Download the default images ZIP using the "Download ZIP" button.</li>
                <li>Uncompress the ZIP file on your computer.</li>
                <li>Replace the default images with your preferred images for each restaurant or menu item, keeping the filenames consistent.</li>
                <li>Re-compress the folder back into a ZIP file.</li>
                <li>Use the form below to upload the edited ZIP file.</li>
                <li>After submitting, the images will be populated in the BistroBase database for each restaurant and menu item.</li>
            </ol>

            <form asp-controller="BulkImport" asp-action="UploadZip" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <input type="file" name="zipFile" class="form-control" accept=".zip" required />
                </div>
                <button type="submit" class="btn btn-primary">Upload ZIP</button>
            </form>
        </div>
       
    }
</div>